# =============================================================================
# Lead Intelligence & Email Discovery Engine — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------
# Application
# -----------------------------------------
APP_ENV=development
LOG_LEVEL=DEBUG
SECRET_KEY=change-me-in-production

# -----------------------------------------
# Database
# Default: local SQLite file, zero setup. Switch to a Postgres DSN
# (postgresql+asyncpg://...) only if you want the Docker/Queue mode.
# -----------------------------------------
DATABASE_URL=sqlite+aiosqlite:///./data/leads.db

# -----------------------------------------
# Redis (only needed for Docker/Queue mode)
# -----------------------------------------
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------
# Crawler Settings
# -----------------------------------------
MAX_WORKERS=4
HTTP_TIMEOUT=15
MAX_RETRIES=3
USER_AGENT=LeadIntelligenceBot/1.0 (+https://github.com/your-org/lead-intelligence)
CRAWL_DELAY=1.0
MAX_PAGES_PER_DOMAIN=20
MAX_CONCURRENT_DOMAINS=10
REQUEST_RATE_PER_SECOND=5.0

# -----------------------------------------
# Playwright (JS Rendering Fallback)
# -----------------------------------------
PLAYWRIGHT_ENABLED=true
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT=30000
PLAYWRIGHT_BROWSER=chromium

# -----------------------------------------
# PDF Extraction
# -----------------------------------------
PDF_ENABLED=false

# -----------------------------------------
# OCR (Requires paddleocr installation)
# -----------------------------------------
OCR_ENABLED=false

# -----------------------------------------
# Email Validation
# -----------------------------------------
SMTP_VALIDATION_ENABLED=false
SMTP_TIMEOUT=10
DNS_TIMEOUT=5.0
MX_VALIDATION_ENABLED=true

# -----------------------------------------
# Confidence Thresholds
# -----------------------------------------
MIN_EMAIL_CONFIDENCE=30
HIGH_CONFIDENCE_THRESHOLD=80

# -----------------------------------------
# Storage (Object Storage — optional)
# -----------------------------------------
OBJECT_STORAGE_ENABLED=false
MINIO_URL=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=crawl-data

# -----------------------------------------
# API
# -----------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
CORS_ORIGINS=["http://localhost:3000"]

# -----------------------------------------
# Queue
# -----------------------------------------
CRAWL_QUEUE_NAME=crawl_jobs
VALIDATION_QUEUE_NAME=validation_jobs
EXPORT_QUEUE_NAME=export_jobs
DEAD_LETTER_QUEUE_NAME=dead_letter
MAX_JOB_RETRIES=3
JOB_TIMEOUT=300

# -----------------------------------------
# Output
# -----------------------------------------
OUTPUT_DIR=output
EXPORT_FORMAT=json

# -----------------------------------------
# Local dashboard batch runner
# -----------------------------------------
CONCURRENT_CRAWLERS=6
BATCH_SIZE=100

# -----------------------------------------
# OpenAI (optional, last-resort summary polish — off by default)
# -----------------------------------------
OPENAI_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
